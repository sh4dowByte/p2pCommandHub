# P2P Command Hub Configuration

# Port the Node.js server will bind to on the host machine
SERVER_PORT=3000

# Server URL the Python agent will connect to.
# For local Docker orchestration, "http://server:3000" connects directly to the server container.
# If left empty, the Python agent will read and fall back to the URL inside config.json.
SERVER_URL=http://server:3000

# Authentication token for WebSocket connections.
# If left empty, the Python agent will read and fall back to the token inside config.json.
SECRET_TOKEN=p2p_secure_agent_token_2026
